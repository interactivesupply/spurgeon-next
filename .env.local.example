NEXT_PUBLIC_WORDPRESS_URL=https://spurgeoncenter.wpengine.com
NEXT_PUBLIC_FAUST_WORDPRESS_URL=https://spurgeoncenter.wpengine.com
FAUST_SECRET_KEY=

# Application Password for an Editor user. Used by SSR Apollo ONLY when in
# preview mode, so WPGraphQL allows `asPreview: true` to return autosaved
# revisions. Server-only — do NOT prefix with NEXT_PUBLIC_.
# Generate with: wp user application-password create <user> "headless-preview" --porcelain
WP_PREVIEW_USER=
WP_PREVIEW_APP_PASSWORD=

MAILGUN_API_KEY=
MAILGUN_DOMAIN=

NEXT_PUBLIC_GA_ID=

# Algolia search (search-only key — safe to expose in browser bundle).
# Read from wp-admin → Algolia plugin settings, or:
#   wp option get algolia_application_id
#   wp option get algolia_search_api_key
#   wp option get algolia_index_name_prefix
# The index is the prefix + "searchable_posts".
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX=

# Live preview shared secret. Must match the WordPress install's
# SPURGEON_PREVIEW_SECRET constant (or the value shown at wp-admin →
# Site Settings → Headless Frontend → Preview Secret).
SPURGEON_PREVIEW_SECRET=

# Userback feedback widget access token. When unset, the widget does not
# load — leave blank in production to keep the feedback button off the
# public site.
NEXT_PUBLIC_USERBACK_TOKEN=
