NEXT_PUBLIC_WORDPRESS_URL=https://spurgeoncenter.wpengine.com
NEXT_PUBLIC_FAUST_WORDPRESS_URL=https://spurgeoncenter.wpengine.com
FAUST_SECRET_KEY=

# Optional: HTTP Basic Auth for the WordPress install (development/staging).
# Set these only on the SSR side. Do NOT prefix with NEXT_PUBLIC_ — credentials
# would leak into client JavaScript. When the WP install no longer requires
# basic auth (production), leave these unset.
WORDPRESS_BASIC_AUTH_USER=
WORDPRESS_BASIC_AUTH_PASSWORD=

MAILGUN_API_KEY=
MAILGUN_DOMAIN=

NEXT_PUBLIC_GA_ID=
